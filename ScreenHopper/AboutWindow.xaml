<Window x:Class="ScreenHopper.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ScreenHopper"
        Width="420" Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FB">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush"     Color="#4F66DA" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#3E54C3" />
        <SolidColorBrush x:Key="PanelBrush"      Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9E0F0" />

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="BorderBrush"  Value="Transparent" />
            <Setter Property="Foreground"   Value="#4F66DA" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="Padding"      Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"
                                   FontSize="{TemplateBinding FontSize}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#3E54C3" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#4F66DA" />
            <Setter Property="Foreground"   Value="White" />
            <Setter Property="BorderBrush"  Value="Transparent" />
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Padding"      Value="28,8" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E54C3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid Margin="28,24,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- App name -->
            <TextBlock Grid.Row="0"
                       Text="ScreenHopper"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#2E3A59"
                       HorizontalAlignment="Center" />

            <!-- Version -->
            <TextBlock Grid.Row="1"
                       x:Name="VersionText"
                       FontSize="12"
                       Foreground="#6B7A99"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />

            <!-- Divider -->
            <Separator Grid.Row="2" Margin="0,14,0,14"
                       Background="#D9E0F0" />

            <!-- Description -->
            <StackPanel Grid.Row="3" VerticalAlignment="Center">
                <TextBlock Text="Move and snap any window to any monitor — instantly."
                           FontSize="13"
                           Foreground="#2E3A59"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />

                <TextBlock Margin="0,10,0,0"
                           FontSize="12"
                           Foreground="#6B7A99"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="Supports GUI and silent CLI operation, per-app preferences,&#x0a;DPI-aware snapping, and automatic updates." />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,14,0,0">
                    <TextBlock Text="GitHub: "
                               FontSize="13"
                               Foreground="#6B7A99"
                               VerticalAlignment="Center" />
                    <Button Style="{StaticResource LinkButtonStyle}"
                            Content="github.com/jon-kim/ScreenHopper"
                            Click="GitHubLink_Click" />
                </StackPanel>

                <TextBlock Margin="0,12,0,0"
                           FontSize="11"
                           Foreground="#A0AABF"
                           HorizontalAlignment="Center"
                           Text="GPLv3 License · © 2025 jon-kim" />
            </StackPanel>

            <!-- Close button -->
            <Button Grid.Row="4"
                    Content="Close"
                    Style="{StaticResource CloseButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
